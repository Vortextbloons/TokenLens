{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TokenLens",
  "version": "0.1.0",
  "identifier": "dev.tokenlens.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TokenLens",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Local-first AI token and cost analytics.",
    "longDescription": "TokenLens is a local-first desktop app that answers: how many AI tokens are you using, where are they going, and what does it cost? No cloud, no AI calls, no telemetry."
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    }
  }
}
